/* pages/index/index.wxss */

.container {
  padding-bottom: 20rpx;
  background-color: #FFFFFF;
  /* 确保从顶部开始 */
  padding-top: 0;
}

/* 轮播图 - 完全全屏显示，顶部不留白 */
.banner-section {
  width: 100%;
  /* 使用固定高度或视口高度 */
  height: 65vh; /* 可以根据需要调整，或者使用 50vh */
  background-color: #ffffff;
  /* 确保从页面最顶部开始 */
  margin-top: 0;
  padding-top: 0;
}

.banner-swiper {
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 推荐商品 */
.recommend-section {
  margin-top: 20rpx;
  background-color: #ffffff;
  padding: 30rpx 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-color);
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--primary-color) 0%, #FFB347 100%);
  border-radius: 3rpx;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-light);
}

.section-more .arrow {
  margin-left: 4rpx;
  font-size: 32rpx;
}

/* 商品网格 - 使用Grid布局实现自适应 */
.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-gap: 20rpx;
  gap: 20rpx;
}

/* 兼容不支持Grid的旧版本微信 */
.goods-grid {
  display: -webkit-grid;
  display: grid;
}

.goods-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  transition: all 0.2s ease;
  min-width: 0; /* 防止内容撑开 */
}

.goods-item:active {
  transform: scale(0.98);
}

.goods-image-wrap {
  width: 100%;
  padding-bottom: 100%; /* 1:1 宽高比 */
  background-color: #f8f8f8;
  position: relative;
  overflow: hidden;
}

.goods-image-wrap .goods-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.goods-info {
  padding: 20rpx;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-color);
  line-height: 1.4;
  height: 78rpx;
}

.goods-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.goods-price {
  font-size: 32rpx;
  font-weight: 600;
}

.goods-cart-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color) 0%, #FFB347 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  transition: all 0.2s ease;
}

.goods-cart-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}
