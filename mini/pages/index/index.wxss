/* pages/index/index.wxss */

.container {
  padding-bottom: 24rpx;
  background-color: var(--background-color);
}

/* 轮播图 */
.banner-section {
  width: 100%;
  height: 56vh;
  background-color: #ffffff;
}

.banner-swiper {
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 快捷操作按钮 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  background-color: #ffffff;
  margin: -40rpx 24rpx 0;
  border-radius: var(--radius-lg);
  padding: 36rpx 16rpx;
  box-shadow: var(--shadow-medium);
  position: relative;
  z-index: 10;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.action-icon:active {
  transform: scale(0.92);
}

.order-icon {
  background: linear-gradient(135deg, #43B77A 0%, #2E9B63 100%);
  box-shadow: 0 4rpx 12rpx rgba(67, 183, 122, 0.3);
}

.recharge-icon {
  background: linear-gradient(135deg, #FF9F43 0%, #EE5A24 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 159, 67, 0.3);
}

.coupon-icon {
  background: linear-gradient(135deg, #EE5A24 0%, #C0392B 100%);
  box-shadow: 0 4rpx 12rpx rgba(238, 90, 36, 0.3);
}

.orderlist-icon {
  background: linear-gradient(135deg, #5F7BAB 0%, #3D5A80 100%);
  box-shadow: 0 4rpx 12rpx rgba(95, 123, 171, 0.3);
}

.icon-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.action-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* 推荐商品 */
.recommend-section {
  margin-top: 24rpx;
  padding: 32rpx 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-dot {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--secondary-color) 100%);
  border-radius: 4rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-color);
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--text-light);
  gap: 4rpx;
}

.section-more .arrow {
  font-size: 32rpx;
}

/* 商品网格 */
.goods-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.goods-item {
  background-color: #ffffff;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-light);
  transition: all 0.2s ease;
}

.goods-item:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-medium);
}

.goods-image-wrap {
  width: 100%;
  padding-bottom: 100%;
  background-color: #f8f8fc;
  position: relative;
  overflow: hidden;
}

.goods-image-wrap .goods-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.goods-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: linear-gradient(135deg, var(--accent-color) 0%, #C0392B 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.goods-info {
  padding: 20rpx 20rpx 24rpx;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
  line-height: 1.4;
}

.goods-desc {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 6rpx;
  display: block;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 16rpx;
}

.goods-price {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.goods-price .price {
  font-size: 34rpx;
}

.original-price {
  font-size: 22rpx;
  color: var(--text-light);
  text-decoration: line-through;
}

.goods-cart-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  box-shadow: 0 4rpx 12rpx rgba(67, 183, 122, 0.3);
  transition: all 0.2s ease;
}

.goods-cart-btn:active {
  transform: scale(0.88);
}
