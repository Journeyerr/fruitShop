/* pages/cart/cart.wxss */

.container {
  min-height: 100vh;
  background-color: var(--background-color);
  padding-bottom: 140rpx;
}

/* 配送信息 */
.delivery-card {
  background-color: #ffffff;
  padding: 32rpx 28rpx;
  margin: 20rpx 24rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-light);
}

.delivery-method {
  margin-bottom: 32rpx;
}

.section-label {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
}

.method-options {
  display: flex;
  gap: 20rpx;
}

.method-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F7F8FC;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.method-item.active {
  background-color: var(--primary-light);
  color: var(--primary-color);
  border-color: var(--primary-color);
  font-weight: 600;
}

.address-section {
  margin-bottom: 32rpx;
}

.address-card {
  display: flex;
  align-items: center;
  background-color: #F7F8FC;
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-top: 20rpx;
}

.address-info {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
  gap: 20rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
}

.address-phone {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.address-detail {
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.5;
}

.address-empty {
  flex: 1;
  text-align: center;
  color: var(--text-light);
  font-size: 28rpx;
}

.arrow {
  color: var(--text-light);
  font-size: 28rpx;
  margin-left: 20rpx;
}

.remark-section {
  margin-bottom: 8rpx;
}

.remark-input {
  width: 100%;
  height: 110rpx;
  background-color: #F7F8FC;
  border-radius: var(--radius-md);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--text-color);
  margin-top: 20rpx;
  box-sizing: border-box;
}

/* 购物车列表 */
.cart-list {
  padding: 0 24rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-light);
}

/* 勾选框 */
.item-check {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.check-box {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  background-color: #ffffff;
}

.check-box.checked {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-color: var(--primary-color);
}

.check-icon {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

/* 商品图片 */
.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  background-color: #F7F8FC;
  flex-shrink: 0;
}

/* 商品内容 */
.item-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 160rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  line-height: 1.4;
}

.item-spec {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.item-price {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--accent-color);
}

/* 步进器 */
.stepper {
  display: flex;
  align-items: center;
  gap: 0;
}

.stepper-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.stepper-btn.minus {
  color: var(--text-light);
  background-color: #F0F1F5;
}

.stepper-btn.minus.min {
  color: #E74C3C;
  background-color: #FFF0EE;
}

.stepper-btn.plus {
  color: #ffffff;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  box-shadow: 0 4rpx 12rpx rgba(67, 183, 122, 0.3);
}

.stepper-btn:active {
  transform: scale(0.88);
}

.stepper-num {
  font-size: 30rpx;
  color: var(--text-color);
  min-width: 60rpx;
  text-align: center;
  font-weight: 700;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-light);
  margin-bottom: 40rpx;
}

.empty-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  padding: 24rpx 80rpx;
  border-radius: var(--radius-xl);
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(67, 183, 122, 0.3);
}

/* 底部结算栏 */
.settlement-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.select-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-all-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.total-info {
  flex: 1;
  text-align: right;
  margin-right: 24rpx;
}

.total-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.total-price {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--accent-color);
}

.submit-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  padding: 22rpx 48rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(67, 183, 122, 0.3);
  white-space: nowrap;
}

.submit-btn:active {
  opacity: 0.85;
}
