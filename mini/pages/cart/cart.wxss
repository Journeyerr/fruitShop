/* pages/cart/cart.wxss */

.container {
  min-height: 100vh;
  background-color: #FAFAFA;
  padding-bottom: 120rpx;
}

/* 顶部配送信息 */
.delivery-section {
  background-color: #ffffff;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.delivery-method {
  margin-bottom: 30rpx;
}

.section-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
  display: block;
}

.method-options {
  display: flex;
  gap: 20rpx;
}

.method-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.method-item.active {
  background-color: #e8f4ff;
  color: #459EE7;
  border-color: #459EE7;
}

.address-section {
  margin-bottom: 30rpx;
}

.address-card {
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 20rpx;
}

.address-info {
  flex: 1;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

.address-empty {
  flex: 1;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.arrow {
  color: #999;
  font-size: 28rpx;
  margin-left: 20rpx;
}

.remark-section {
  margin-bottom: 10rpx;
}

.remark-input {
  width: 100%;
  height: 110rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 15rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  margin-top: 20rpx;
}

/* 购物车列表 */
.cart-list {
  padding: 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.item-check {
  margin-right: 20rpx;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

.item-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 160rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-color);
}

.item-unit {
  font-size: 24rpx;
  color: var(--text-light);
}

.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-footer .price {
  font-size: 32rpx;
  font-weight: bold;
}

.quantity-control {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 50rpx;
  overflow: hidden;
}

.quantity-control view {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.btn-minus {
  color: var(--text-light);
}

.btn-plus {
  background-color: var(--primary-color);
  color: #ffffff;
}

.quantity {
  font-size: 28rpx;
  color: var(--text-color);
  min-width: 50rpx;
  text-align: center;
}

.item-delete {
  padding: 10rpx 20rpx;
  color: var(--text-light);
  font-size: 24rpx;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-image {
  width: 300rpx;
  height: 300rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-light);
  margin-bottom: 40rpx;
}

.empty-btn {
  background-color: var(--primary-color);
  color: #ffffff;
  padding: 20rpx 80rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
}

/* 底部结算栏 */
.settlement-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.select-all {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-color);
}

.select-all checkbox {
  margin-right: 10rpx;
}

.total-info {
  flex: 1;
  text-align: right;
  margin-right: 20rpx;
}

.total-label {
  font-size: 28rpx;
  color: var(--text-color);
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--warning-color);
}

.submit-btn {
  background-color: var(--primary-color);
  color: #ffffff;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}
