<!--pages/cart/cart.wxml-->
<view class="container">
  <!-- 配送信息 -->
  <view class="delivery-card" wx:if="{{isLogin && cart.length > 0}}">
    <!-- 配送方式 -->
    <view class="delivery-method">
      <text class="section-label">配送方式</text>
      <view class="method-options">
        <view class="method-item {{deliveryMethod === 'pickup' ? 'active' : ''}}" bindtap="selectDeliveryMethod" data-method="pickup">
          <text>到店自提</text>
        </view>
        <view class="method-item {{deliveryMethod === 'delivery' ? 'active' : ''}}" bindtap="selectDeliveryMethod" data-method="delivery">
          <text>外卖配送</text>
        </view>
      </view>
    </view>

    <!-- 地址选择 -->
    <view class="address-section" wx:if="{{deliveryMethod === 'delivery'}}">
      <text class="section-label">收货地址</text>
      <view class="address-card" bindtap="selectAddress">
        <block wx:if="{{selectedAddress}}">
          <view class="address-info">
            <view class="address-header">
              <text class="address-name">{{selectedAddress.name}}</text>
              <text class="address-phone">{{selectedAddress.phone}}</text>
            </view>
            <text class="address-detail">{{selectedAddress.fullAddress}}</text>
          </view>
        </block>
        <block wx:else>
          <view class="address-empty">
            <text>请选择收货地址</text>
          </view>
        </block>
        <text class="arrow">></text>
      </view>
    </view>

    <!-- 备注 -->
    <view class="remark-section">
      <text class="section-label">订单备注</text>
      <textarea class="remark-input" placeholder="请输入备注信息（选填）" value="{{remark}}" bindinput="onRemarkInput" maxlength="100" />
    </view>
  </view>

  <!-- 购物车列表 -->
  <view class="cart-list" wx:if="{{isLogin && cart.length > 0}}">
    <view class="cart-item" wx:for="{{cart}}" wx:key="id">
      <!-- 左侧勾选 -->
      <view class="item-check" bindtap="toggleSelect" data-index="{{index}}">
        <view class="check-box {{item.selected !== false ? 'checked' : ''}}">
          <text class="check-icon" wx:if="{{item.selected !== false}}">✓</text>
        </view>
      </view>
      <!-- 商品图片 -->
      <image class="item-image" src="{{item.image}}" mode="aspectFill"></image>
      <!-- 商品信息 -->
      <view class="item-content">
        <text class="item-name text-ellipsis">{{item.name}}</text>
        <text class="item-spec text-ellipsis">{{item.unit}}</text>
        <view class="item-bottom">
          <text class="item-price">¥{{item.price}}</text>
          <view class="stepper">
            <view class="stepper-btn minus {{item.quantity === 1 ? 'min' : ''}}" bindtap="decrease" data-index="{{index}}">
              <text>-</text>
            </view>
            <text class="stepper-num">{{item.quantity}}</text>
            <view class="stepper-btn plus" bindtap="increase" data-index="{{index}}">
              <text>+</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 未登录提示 -->
  <view class="empty-state" wx:if="{{!isLogin}}">
    <image class="empty-image" src="/images/empty-cart.png" mode="aspectFit"></image>
    <text class="empty-text">请登录后查看购物车</text>
    <view class="empty-btn" bindtap="goLogin">去登录</view>
  </view>

  <!-- 空购物车 -->
  <view class="empty-state" wx:elif="{{cart.length === 0}}">
    <image class="empty-image" src="/images/empty-cart.png" mode="aspectFit"></image>
    <text class="empty-text">购物车是空的</text>
    <view class="empty-btn" bindtap="goShopping">去选购</view>
  </view>

  <!-- 底部结算栏 -->
  <view class="settlement-bar safe-bottom" wx:if="{{isLogin && cart.length > 0}}">
    <view class="select-all" bindtap="selectAll">
      <view class="check-box {{allSelected ? 'checked' : ''}}">
        <text class="check-icon" wx:if="{{allSelected}}">✓</text>
      </view>
      <text class="select-all-text">全选</text>
    </view>
    <view class="total-info">
      <text class="total-label">合计</text>
      <text class="total-price">¥{{totalPrice}}</text>
    </view>
    <view class="submit-btn" bindtap="submitOrder">
      <text>提交订单{{selectedCount > 0 ? '(' + selectedCount + ')' : ''}}</text>
    </view>
  </view>
</view>
