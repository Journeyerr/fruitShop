/* pages/goods/goods.wxss */

.container {
  display: flex;
  height: 100vh;
  background-color: var(--background-color);
}

/* 左侧分类栏 */
.category-sidebar {
  width: 180rpx;
  height: 100%;
  background-color: #F0F1F5;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 12rpx;
  position: relative;
  transition: all 0.25s ease;
}

.category-item.active {
  background-color: #ffffff;
}

.category-indicator {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 0 3rpx 3rpx 0;
}

.category-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
  transition: all 0.25s ease;
  line-height: 1.3;
  margin-top: 6rpx;
}

.category-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
}

.category-item.active .category-name {
  color: var(--primary-color);
  font-weight: 700;
  font-size: 28rpx;
}

/* 右侧商品内容 */
.goods-content {
  flex: 1;
  height: 100%;
  background-color: #ffffff;
  padding: 20rpx 24rpx 160rpx;
}

/* 分类区块 */
.goods-section {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
  padding: 20rpx 0 24rpx;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: 16rpx;
  width: 36rpx;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color) 0%, transparent 100%);
  border-radius: 2rpx;
}

/* 商品列表 */
.goods-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.goods-card {
  display: flex;
  background-color: #ffffff;
  border-radius: var(--radius-md);
  padding: 20rpx;
  border: 1rpx solid var(--border-color);
  transition: all 0.2s ease;
}

.goods-card:active {
  transform: scale(0.98);
  border-color: var(--primary-light);
}

.goods-image-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  background-color: #f8f8fc;
  flex-shrink: 0;
  overflow: hidden;
}

.goods-image {
  width: 100%;
  height: 100%;
}

.goods-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  line-height: 1.4;
}

.goods-desc {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 6rpx;
}

.goods-footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 12rpx;
}

.price-wrap {
  display: flex;
  align-items: baseline;
}

.price-wrap .price {
  font-size: 34rpx;
}

.unit {
  font-size: 22rpx;
  color: var(--text-light);
  margin-left: 2rpx;
}

.add-btn {
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 300;
  box-shadow: 0 4rpx 12rpx rgba(67, 183, 122, 0.25);
  transition: all 0.2s ease;
}

.add-btn:active {
  transform: scale(0.88);
}

/* 购物车悬浮按钮 */
.cart-float-btn {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  bottom: 40rpx;
  width: 680rpx;
  height: 100rpx;
  background-color: #3D4059;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 30rpx rgba(61, 64, 89, 0.3);
  display: flex;
  align-items: center;
  padding: 0 8rpx 0 0;
  z-index: 999;
}

.cart-left {
  flex: 1;
  display: flex;
  align-items: center;
  padding-left: 16rpx;
}

.cart-icon-wrap {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(67, 183, 122, 0.35);
  margin-top: -20rpx;
}

.cart-icon {
  width: 44rpx;
  height: 44rpx;
}

.cart-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: linear-gradient(135deg, var(--accent-color) 0%, #C0392B 100%);
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  font-weight: 600;
  border: 2rpx solid #2A2D3E;
}

.cart-price-wrap {
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
}

.cart-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

.cart-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.cart-submit-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  padding: 22rpx 44rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.cart-submit-btn:active {
  opacity: 0.85;
}

/* 商品详情弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.modal-content {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 640rpx;
  max-height: 80vh;
  background-color: #ffffff;
  border-radius: var(--radius-lg);
  z-index: 1001;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  position: relative;
  width: 100%;
  height: 400rpx;
  flex-shrink: 0;
}

.modal-image {
  width: 100%;
  height: 100%;
}

.modal-close {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background-color: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
}

.modal-body {
  flex: 1;
  padding: 28rpx 32rpx;
  max-height: 50vh;
}

.modal-info {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-color);
  line-height: 1.4;
}

.modal-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 16rpx;
  gap: 8rpx;
}

.modal-price {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--accent-color);
}

.modal-unit {
  font-size: 24rpx;
  color: var(--text-light);
}

.modal-original-price {
  font-size: 24rpx;
  color: var(--text-light);
  text-decoration: line-through;
  margin-left: 8rpx;
}

.modal-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.modal-tag {
  font-size: 22rpx;
  color: var(--text-secondary);
  background-color: #F5F6FA;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.modal-desc,
.modal-detail {
  padding: 24rpx 0;
}

.modal-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 12rpx;
  display: block;
}

.modal-section-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  display: block;
}

.modal-footer {
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border-color);
  flex-shrink: 0;
}

.modal-add-btn {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: var(--radius-xl);
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(67, 183, 122, 0.3);
}

.modal-add-btn:active {
  opacity: 0.85;
}
