/* pages/user/user.wxss */

.container {
  min-height: 100vh;
  background-color: #FAFAFA;
  padding-bottom: 20rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg,rgb(166, 198, 224) 0%,rgb(110, 137, 196) 100%);
  padding: 100rpx 50rpx 100rpx;
}

.user-info {
  display: flex;
  align-items: center;
  position: relative;
  min-height: 140rpx;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background-color: #ffffff;
  flex-shrink: 0;
}

.user-content {
  margin-left: 30rpx;
  color: #ffffff;
  flex: 1;
}

.login-btn {
  background-color: #ffffff;
  color:rgb(120, 176, 209);
  padding: 24rpx 64rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  line-height: normal;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 16rpx;
}

.login-btn::after {
  border: none;
}

.login-tip {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 16rpx;
}

.user-name {
  display: block;
  font-size: 38rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.user-phone {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
}

.logout-button {
  width: 100%;
  height: 88rpx;
  background-color: #ffffff;
  color: #73b0da;
  font-size: 32rpx;
  font-weight: 500;
  border: 2rpx solid #a1c8ec;
  border-radius: 12rpx;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-button::after {
  border: none;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  margin: 20rpx;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 订单快捷入口 */
.order-card {
  margin-top: -40rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.order-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
}

.order-more {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--text-light);
}

.arrow {
  font-size: 32rpx;
  margin-left: 4rpx;
}

.order-icons {
  display: flex;
  justify-content: space-around;
}

.order-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
}

.icon-wrap image {
  width: 100%;
  height: 100%;
}

.badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: var(--warning-color);
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* 配送信息 */
.delivery-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.delivery-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.delivery-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
}

.delivery-info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.delivery-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
}

.delivery-label {
  color: var(--text-secondary);
}

.delivery-value {
  color: var(--text-color);
}

.delivery-value.highlight {
  color: var(--primary-color);
  font-weight: 500;
}

/* 功能菜单 */
.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
}

.menu-name {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-color);
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-badge {
  font-size: 26rpx;
  color: var(--warning-color);
  margin-right: 8rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin-top: 30rpx;
}

/* 客服热线 */
.service-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.service-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
}

.service-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-color);
}
