/* pages/user/user.wxss */

.container {
  min-height: 100vh;
  background-color: var(--background-color);
  padding-bottom: 40rpx;
}

/* 用户信息卡片 */
.user-card {
  position: relative;
  overflow: hidden;
}

.user-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #43B77A 0%, #2E9B63 50%, #1F8050 100%);
}

.user-content {
  position: relative;
  z-index: 2;
  padding: 100rpx 48rpx 80rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 48rpx;
  font-weight: 300;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  background-color: #ffffff;
  flex-shrink: 0;
}

.user-detail {
  margin-left: 28rpx;
  color: #ffffff;
  flex: 1;
}

.login-btn {
  background-color: rgba(255, 255, 255, 0.95);
  color: var(--primary-color);
  padding: 20rpx 56rpx;
  border-radius: var(--radius-xl);
  font-size: 30rpx;
  font-weight: 700;
  border: none;
  line-height: normal;
  display: inline-flex;
  margin-bottom: 12rpx;
}

.login-btn::after {
  border: none;
}

.login-tip {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.user-phone {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
}

/* 钱包卡片 */
.wallet-card {
  display: flex;
  background-color: #ffffff;
  margin: -36rpx 24rpx 0;
  border-radius: var(--radius-lg);
  padding: 36rpx 0;
  box-shadow: var(--shadow-medium);
  position: relative;
  z-index: 10;
}

.wallet-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.wallet-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-color);
}

.wallet-label {
  font-size: 24rpx;
  color: var(--text-light);
}

.wallet-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: var(--border-color);
  align-self: center;
}

/* 订单卡片 */
.order-card {
  background-color: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-light);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.order-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-color);
}

.order-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--text-light);
  gap: 4rpx;
}

.arrow {
  font-size: 32rpx;
  color: var(--text-light);
}

.order-icons {
  display: flex;
  justify-content: space-around;
}

.order-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 4rpx;
}

.icon-wrap image {
  width: 100%;
  height: 100%;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: linear-gradient(135deg, var(--accent-color) 0%, #C0392B 100%);
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  font-weight: 600;
}

/* 菜单卡片 */
.menu-card {
  background-color: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: var(--radius-lg);
  padding: 8rpx 32rpx 32rpx;
  box-shadow: var(--shadow-light);
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-icon-wrap.bg-green {
  /* background-color: var(--primary-light); */
}

.menu-icon-wrap.bg-orange {
  /* background-color: #FFF3EE; */
}

.menu-icon-wrap.bg-blue {
  /* background-color: #EEF2F7; */
}

.menu-icon-wrap.bg-red {
  /* background-color: #FFF0F0; */
}

.menu-icon-wrap.bg-purple {
  /* background-color: #F3EEFF; */
}

.menu-icon-wrap.bg-gray {
  /* background-color: #F7F8FC; */
}

.menu-icon {
  width: 36rpx;
  height: 36rpx;
}

.menu-name {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-color);
  font-weight: 500;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-badge {
  font-size: 24rpx;
  color: var(--accent-color);
  margin-right: 8rpx;
  font-weight: 600;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin-top: 24rpx;
}

/* 退出登录 */
.logout-button {
  width: 100%;
  height: 88rpx;
  background-color: #ffffff;
  color: var(--accent-color);
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid #FFD5C8;
  border-radius: var(--radius-md);
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
}

.logout-button::after {
  border: none;
}
