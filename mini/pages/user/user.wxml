<!--pages/user/user.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-bg"></view>
    <view class="user-content">
      <!-- 未登录状态 -->
      <view class="user-info" wx:if="{{!isLogin}}">
        <view class="avatar-placeholder">
          <text class="avatar-text">?</text>
        </view>
        <view class="user-detail">
          <button class="login-btn" bindtap="getUserProfile">微信登录</button>
          <text class="login-tip">登录后享受更多权益</text>
        </view>
      </view>
      
      <!-- 已登录状态 -->
      <view class="user-info" wx:else>
        <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
        <view class="user-detail">
          <text class="user-name">{{userInfo.nickname}}</text>
          <text class="user-phone">{{userInfo.phone || '未绑定手机'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 钱包卡片 -->
  <view class="wallet-card" wx:if="{{isLogin}}">
    <view class="wallet-item" bindtap="goToRecharge">
      <text class="wallet-value">{{walletInfo.balance || '0.00'}}</text>
      <text class="wallet-label">余额(元)</text>
    </view>
    <view class="wallet-divider"></view>
    <view class="wallet-item" bindtap="goToCoupon">
      <text class="wallet-value">{{walletInfo.couponCount || 0}}</text>
      <text class="wallet-label">优惠券</text>
    </view>
    <view class="wallet-divider"></view>
    <view class="wallet-item">
      <text class="wallet-value">{{walletInfo.points || 0}}</text>
      <text class="wallet-label">积分</text>
    </view>
  </view>

  <!-- 订单快捷入口 -->
  <view class="order-card">
    <view class="order-header">
      <text class="order-title">我的订单</text>
      <view class="order-more" bindtap="viewOrders">
        <text>全部订单</text>
        <text class="arrow">›</text>
      </view>
    </view>
    <view class="order-icons">
      <view class="order-icon-item" bindtap="viewOrders" data-status="0">
        <view class="icon-wrap">
          <image src="/images/order-pending.png" mode="aspectFit"></image>
          <view class="badge" wx:if="{{orderCounts.pending > 0}}">{{orderCounts.pending}}</view>
        </view>
        <text>待付款</text>
      </view>
      <view class="order-icon-item" bindtap="viewOrders" data-status="2">
        <view class="icon-wrap">
          <image src="/images/order-paid.png" mode="aspectFit"></image>
          <view class="badge" wx:if="{{orderCounts.delivering > 0}}">{{orderCounts.delivering}}</view>
        </view>
        <text>配送中</text>
      </view>
      <view class="order-icon-item" bindtap="viewOrders" data-status="3">
        <view class="icon-wrap">
          <image src="/images/order-completed.png" mode="aspectFit"></image>
          <view class="badge" wx:if="{{orderCounts.completed > 0}}">{{orderCounts.completed}}</view>
        </view>
        <text>已完成</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card">
    <view class="menu-list">
      <view class="menu-item" wx:for="{{menuItems}}" wx:key="id"
            bindtap="{{item.id === 'service' ? 'callService' : 'onMenuTap'}}"
            data-id="{{item.id}}">
        <view class="menu-icon-wrap {{item.iconBg}}">
          <image class="menu-icon" src="{{item.icon}}" mode="aspectFit"></image>
        </view>
        <text class="menu-name">{{item.name}}</text>
        <view class="menu-right">
          <text class="menu-badge" wx:if="{{item.badge}}">{{item.badge}}</text>
          <text class="arrow" wx:if="{{item.id !== 'service'}}">›</text>
        </view>
      </view>
    </view>

    <view class="divider" wx:if="{{isLogin}}"></view>

    <button class="logout-button" wx:if="{{isLogin}}" bindtap="logout">
      退出登录
    </button>
  </view>
</view>
