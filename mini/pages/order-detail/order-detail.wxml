<!--pages/order-detail/order-detail.wxml-->
<view class="container" wx:if="{{order}}">
  <!-- 订单状态 -->
  <view class="status-card status-{{order.status}}">
    <view class="status-content">
      <view class="status-main">
        <view class="status-icon-wrap">
          <image class="status-icon-img" src="/images/{{order.status === 'pending' ? 'order-pending' : (order.status === 'to-deliver' || order.status === 'delivering') ? 'order-paid' : 'order-completed'}}.png" mode="aspectFit"></image>
        </view>
        <view class="status-info">
          <text class="status-text">{{order.statusText}}</text>
          <text class="status-desc">{{order.status === 'pending' ? '请在30分钟内完成支付' : order.status === 'to-deliver' ? '商家正在准备发货' : order.status === 'delivering' ? '商品正在配送中' : order.status === 'completed' ? '订单已完成，期待下次光临' : '订单已取消'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 收货地址（配送订单才显示） -->
  <view class="address-card card" wx:if="{{order.deliveryMethod === 'delivery' && order.address}}">
    <view class="address-header">
      <image src="/images/location.png" mode="aspectFit" class="address-icon"></image>
      <text class="address-title">收货信息</text>
    </view>
    <view class="address-content">
      <view class="address-info">
        <text class="address-name">{{order.address.name}}</text>
        <text class="address-phone">{{order.address.phone}}</text>
      </view>
      <text class="address-detail">{{order.address.address}}</text>
    </view>
  </view>

  <!-- 自提信息 -->
  <view class="pickup-card card" wx:if="{{order.deliveryMethod === 'pickup'}}">
    <view class="pickup-header">
      <image src="/images/location.png" mode="aspectFit" class="pickup-icon"></image>
      <text class="pickup-title">自提信息</text>
    </view>
    <view class="pickup-content">
      <text class="pickup-tip">请到门店自提商品</text>
      <text class="pickup-address">门店地址：XX路XX号</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="goods-card card">
    <view class="card-header">
      <text class="card-title">商品信息</text>
      <text class="goods-count">共{{order.goodsCount}}件</text>
    </view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{order.goods}}" wx:key="id">
        <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="goods-content">
          <text class="goods-name text-ellipsis">{{item.name}}</text>
          <view class="goods-meta">
            <text class="goods-unit">{{item.unit}}</text>
            <text class="goods-quantity">x{{item.quantity}}</text>
          </view>
          <text class="goods-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="info-card card">
    <view class="card-header">
      <text class="card-title">订单信息</text>
    </view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">订单编号</text>
        <view class="info-value">
          <text>{{order.id}}</text>
          <text class="copy-btn" bindtap="copyOrderId">复制</text>
        </view>
      </view>
      <view class="info-item">
        <text class="info-label">下单时间</text>
        <text class="info-value">{{order.createTime}}</text>
      </view>
      <view class="info-item" wx:if="{{order.payTime}}">
        <text class="info-label">支付时间</text>
        <text class="info-value">{{order.payTime}}</text>
      </view>
      <view class="info-item" wx:if="{{order.deliverTime}}">
        <text class="info-label">配送时间</text>
        <text class="info-value">{{order.deliverTime}}</text>
      </view>
      <view class="info-item" wx:if="{{order.completeTime}}">
        <text class="info-label">完成时间</text>
        <text class="info-value">{{order.completeTime}}</text>
      </view>
      <view class="info-item" wx:if="{{order.remark}}">
        <text class="info-label">订单备注</text>
        <text class="info-value">{{order.remark}}</text>
      </view>
    </view>
  </view>

  <!-- 金额明细 -->
  <view class="amount-card card">
    <view class="amount-item">
      <text class="amount-label">商品总额</text>
      <text class="amount-value">¥{{order.totalPrice}}</text>
    </view>
    <view class="amount-item">
      <text class="amount-label">配送费</text>
      <text class="amount-value">¥0.00</text>
    </view>
    <view class="amount-item total">
      <text class="amount-label">实付金额</text>
      <text class="amount-value price">¥{{order.totalPrice}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="contact-btn" bindtap="contactMerchant">
      <image src="/images/phone.png" mode="aspectFit"></image>
      <text>联系商家</text>
    </view>
    <view class="action-btns">
      <view class="action-btn secondary"
            wx:if="{{order.status === 'pending'}}"
            bindtap="cancelOrder">
        取消订单
      </view>
      <view class="action-btn primary"
            wx:if="{{order.status === 'pending'}}"
            bindtap="payOrder">
        立即支付
      </view>
      <view class="action-btn primary"
            wx:if="{{order.status === 'delivering' || order.status === 'to-deliver'}}"
            bindtap="confirmReceive">
        确认收货
      </view>
      <view class="action-btn primary"
            wx:if="{{order.status === 'completed'}}" 
            bindtap="reorder">
        再来一单
      </view>
    </view>
  </view>
</view>
