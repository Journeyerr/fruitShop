/* pages/order-detail/order-detail.wxss */

.container {
  min-height: 100vh;
  background-color: #FAFAFA;
  padding-bottom: 120rpx;
}

/* 订单状态 */
.status-card {
  padding: 50rpx 40rpx;
  position: relative;
  overflow: hidden;
}

/* 不同状态的背景色 */
.status-pending {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.status-to-deliver {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.status-delivering {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.status-completed {
  background: linear-gradient(135deg, #56ab2f 0%, #a8e063 100%);
}

.status-cancelled {
  background: linear-gradient(135deg, #bdc3c7 0%, #95a5a6 100%);
}

/* 背景装饰 */
.status-card::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.status-card::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -30rpx;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.status-content {
  position: relative;
  z-index: 1;
}

.status-main {
  display: flex;
  align-items: center;
}

.status-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.status-icon-img {
  width: 60rpx;
  height: 60rpx;
}

.status-info {
  display: flex;
  flex-direction: column;
}

.status-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.status-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  margin: 20rpx;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
}

.goods-count {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 收货地址 */
.address-card {
  margin-top: -20rpx;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.address-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.address-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
}

.address-content {
  display: flex;
  flex-direction: column;
}

.address-info {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-color);
  margin-right: 20rpx;
}

.address-phone {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.address-detail {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 自提信息 */
.pickup-card {
  margin-top: -20rpx;
}

.pickup-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.pickup-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.pickup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-color);
}

.pickup-content {
  display: flex;
  flex-direction: column;
}

.pickup-tip {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.pickup-address {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 商品列表 */
.goods-list {
  display: flex;
  flex-direction: column;
}

.goods-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

.goods-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 30rpx;
  color: var(--text-color);
  font-weight: 500;
}

.goods-meta {
  display: flex;
  font-size: 26rpx;
  color: var(--text-light);
}

.goods-unit {
  margin-right: 20rpx;
}

.goods-price {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--warning-color);
}

/* 订单信息 */
.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-color);
  display: flex;
  align-items: center;
}

.copy-btn {
  margin-left: 16rpx;
  color: var(--primary-color);
  font-size: 26rpx;
}

/* 金额明细 */
.amount-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.amount-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.amount-value {
  font-size: 28rpx;
  color: var(--text-color);
}

.amount-item.total {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.amount-item.total .amount-label {
  font-weight: bold;
  color: var(--text-color);
}

.amount-item.total .amount-value {
  font-size: 36rpx;
  font-weight: bold;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.contact-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 30rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.contact-btn image {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.action-btns {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.action-btn {
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.action-btn.primary {
  background-color: var(--primary-color);
  color: #ffffff;
}

.action-btn.secondary {
  background-color: #ffffff;
  color: var(--text-secondary);
  border: 1rpx solid var(--border-color);
}
