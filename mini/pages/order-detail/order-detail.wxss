/* pages/order-detail/order-detail.wxss */

.container {
  min-height: 100vh;
  background-color: var(--background-color);
  padding-bottom: 140rpx;
}

/* 订单状态 */
.status-card {
  background: linear-gradient(135deg, #43B77A 0%, #2E9B63 100%);
  padding: 48rpx 40rpx 56rpx;
  color: #ffffff;
}

.status-card.status-pending {
  background: linear-gradient(135deg, #FF9F43 0%, #EE5A24 100%);
}

.status-card.status-cancelled {
  background: linear-gradient(135deg, #9CA3AF 0%, #6B7280 100%);
}

.status-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.status-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.status-icon-img {
  width: 48rpx;
  height: 48rpx;
}

.status-info {
  flex: 1;
}

.status-text {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-desc {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
}

/* 卡片通用 */
.card {
  background-color: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-light);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
}

.goods-count {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 收货地址 */
.address-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.address-icon {
  width: 32rpx;
  height: 32rpx;
}

.address-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
}

.address-content {
  padding-left: 44rpx;
}

.address-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
}

.address-phone {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.address-detail {
  font-size: 26rpx;
  color: var(--text-light);
  line-height: 1.5;
}

/* 自提信息 */
.pickup-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.pickup-icon {
  width: 32rpx;
  height: 32rpx;
}

.pickup-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
}

.pickup-content {
  padding-left: 44rpx;
}

.pickup-tip {
  display: block;
  font-size: 28rpx;
  color: var(--text-color);
  margin-bottom: 8rpx;
}

.pickup-address {
  display: block;
  font-size: 26rpx;
  color: var(--text-light);
}

/* 商品列表 */
.goods-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  background-color: #F7F8FC;
  flex-shrink: 0;
}

.goods-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 120rpx;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
}

.goods-unit {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.goods-bottom {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.goods-quantity {
  font-size: 24rpx;
  color: var(--text-light);
}

.goods-price {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--accent-color);
}

/* 订单信息 */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-color);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.copy-btn {
  font-size: 24rpx;
  color: var(--primary-color);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  background-color: var(--primary-light);
}

/* 金额明细 */
.amount-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.amount-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.amount-value {
  font-size: 28rpx;
  color: var(--text-color);
}

.amount-item.total {
  border-top: 1rpx solid var(--border-color);
  margin-top: 12rpx;
  padding-top: 20rpx;
}

.amount-item.total .amount-label {
  font-weight: 600;
  color: var(--text-color);
}

.amount-item.total .amount-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--accent-color);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.contact-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.contact-btn image {
  width: 40rpx;
  height: 40rpx;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 18rpx 40rpx;
  border-radius: var(--radius-xl);
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn.secondary {
  background-color: #F7F8FC;
  color: var(--text-secondary);
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(67, 183, 122, 0.25);
}

.action-btn:active {
  opacity: 0.85;
}
