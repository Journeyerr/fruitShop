/* pages/coupon/coupon.wxss */

.container {
  min-height: 100vh;
  background-color: var(--background-color);
}

/* 标签栏 */
.tabs {
  display: flex;
  background-color: #ffffff;
  padding: 0 24rpx;
  box-shadow: var(--shadow-light);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
  transition: all 0.25s ease;
}

.tab-item.active {
  color: var(--primary-color);
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  border-radius: 3rpx;
}

/* 优惠券列表 */
.coupon-list {
  padding: 24rpx;
}

.coupon-item {
  display: flex;
  align-items: stretch;
  background-color: #ffffff;
  border-radius: var(--radius-lg);
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-light);
  position: relative;
}

.coupon-item.used,
.coupon-item.expired {
  opacity: 0.55;
}

.coupon-left {
  width: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 20rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  flex-shrink: 0;
}

.coupon-item.used .coupon-left,
.coupon-item.expired .coupon-left {
  background: linear-gradient(135deg, #9CA3AF 0%, #6B7280 100%);
}

.coupon-amount {
  display: flex;
  align-items: baseline;
}

.symbol {
  font-size: 28rpx;
  font-weight: 600;
}

.number {
  font-size: 60rpx;
  font-weight: 800;
  line-height: 1;
}

.coupon-condition {
  font-size: 22rpx;
  margin-top: 8rpx;
  opacity: 0.9;
}

/* 分割线 */
.coupon-divider {
  width: 2rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.circle {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: var(--background-color);
  position: absolute;
}

.circle.top {
  top: -12rpx;
}

.circle.bottom {
  bottom: -12rpx;
}

.dashed {
  flex: 1;
  width: 0;
  border-left: 2rpx dashed rgba(0, 0, 0, 0.08);
  margin: 24rpx 0;
}

/* 右侧 */
.coupon-right {
  flex: 1;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  position: relative;
}

.coupon-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-color);
}

.coupon-time {
  font-size: 22rpx;
  color: var(--text-light);
}

.coupon-type {
  font-size: 22rpx;
  color: var(--primary-color);
  background-color: var(--primary-light);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  display: inline-flex;
  align-self: flex-start;
  margin-top: 4rpx;
}

.coupon-item.used .coupon-type,
.coupon-item.expired .coupon-type {
  color: var(--text-light);
  background-color: #F7F8FC;
}

.coupon-status-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 20rpx;
  color: var(--text-light);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background-color: #F7F8FC;
}

/* 使用按钮 */
.coupon-btn {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-xl);
}

.coupon-btn:active {
  opacity: 0.85;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-light);
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
  color: var(--text-light);
  font-size: 28rpx;
}
