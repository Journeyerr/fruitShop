/* pages/coupon/coupon.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 标签切换 */
.tabs {
  display: flex;
  background-color: #fff;
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 16rpx 0;
  position: relative;
}

.tab-item.active {
  color: #459EE7;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #459EE7;
  border-radius: 2rpx;
}

/* 优惠券列表 */
.coupon-list {
  padding: 20rpx;
}

.coupon-item {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.coupon-item.used,
.coupon-item.expired {
  opacity: 0.6;
}

.coupon-left {
  width: 200rpx;
  background: linear-gradient(135deg, #459EE7, #6BB9F7);
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.coupon-item.used .coupon-left {
  background: linear-gradient(135deg, #999, #bbb);
}

.coupon-item.expired .coupon-left {
  background: linear-gradient(135deg, #ccc, #ddd);
}

.coupon-amount {
  display: flex;
  align-items: baseline;
}

.coupon-amount .symbol {
  font-size: 32rpx;
  font-weight: bold;
}

.coupon-amount .number {
  font-size: 56rpx;
  font-weight: bold;
  line-height: 1;
}

.coupon-condition {
  font-size: 22rpx;
  margin-top: 10rpx;
}

.coupon-right {
  flex: 1;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.coupon-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.coupon-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.coupon-type {
  font-size: 22rpx;
  color: #459EE7;
  background-color: rgba(69, 158, 231, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  display: inline-block;
  width: fit-content;
}

.coupon-status {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 100rpx;
  height: 100rpx;
}

.coupon-status image {
  width: 100%;
  height: 100%;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty text {
  font-size: 28rpx;
  color: #999;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
