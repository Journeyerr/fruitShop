<!--pages/coupon/coupon.wxml-->
<view class="container">
  <!-- 标签切换 -->
  <view class="tabs">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
      可使用({{usableCount}})
    </view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
      已使用({{usedCount}})
    </view>
    <view class="tab-item {{currentTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">
      已过期({{expiredCount}})
    </view>
  </view>

  <!-- 优惠券列表 -->
  <view class="coupon-list" wx:if="{{coupons.length > 0}}">
    <view class="coupon-item {{item.status === 1 ? 'used' : item.status === 2 ? 'expired' : ''}}" 
          wx:for="{{coupons}}" 
          wx:key="id">
      <view class="coupon-left">
        <view class="coupon-amount">
          <text class="symbol">¥</text>
          <text class="number">{{item.amount}}</text>
        </view>
        <text class="coupon-condition">满{{item.minAmount}}元可用</text>
      </view>
      <view class="coupon-divider">
        <view class="circle top"></view>
        <view class="dashed"></view>
        <view class="circle bottom"></view>
      </view>
      <view class="coupon-right">
        <text class="coupon-name">{{item.couponName}}</text>
        <text class="coupon-time">{{item.startTime}} - {{item.endTime}}</text>
        <text class="coupon-type">{{item.couponType === 1 ? '满减券' : '折扣券'}}</text>
        <view class="coupon-status-tag" wx:if="{{item.status !== 0}}">
          <text>{{item.status === 1 ? '已使用' : '已过期'}}</text>
        </view>
      </view>
      <view class="coupon-btn" wx:if="{{item.status === 0}}" catchtap="useCoupon">
        去使用
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{coupons.length === 0 && !loading}}">
    <text class="empty-text">暂无优惠券</text>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
