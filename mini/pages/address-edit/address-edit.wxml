<view class="address-edit">
  <view class="form">
    <view class="form-item">
      <text class="label">收货人</text>
      <input class="input" placeholder="请输入收货人姓名" value="{{name}}" bindinput="onNameInput" />
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" maxlength="11" value="{{phone}}" bindinput="onPhoneInput" />
    </view>

    <view class="form-item">
      <text class="label">所在地区</text>
      <picker mode="multiSelector" bindchange="onRegionChange" bindcolumnchange="onRegionColumnChange" value="{{regionIndex}}" range="{{regionData}}">
        <view class="region-picker">
          <text class="region-text {{region ? '' : 'placeholder'}}">
            {{region ? region : '请选择省市区'}}
          </text>
          <text class="arrow"></text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">详细地址</text>
      <textarea class="textarea" placeholder="请输入详细地址" value="{{detail}}" bindinput="onDetailInput" />
    </view>

    <view class="form-item switch-item">
      <text class="label">设为默认地址</text>
      <switch checked="{{isDefault}}" bindchange="onDefaultChange" color="#459EE7" />
    </view>
  </view>

  <view class="btn-group">
    <button class="save-btn" bindtap="onSave">保存</button>
  </view>
</view>
