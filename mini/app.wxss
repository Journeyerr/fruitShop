/* app.wxss - 全局样式 */

/* 引入WeUI */
@import './styles/weui.wxss';

/* 主题色变量 */
page {
  --primary-color: #FF6B35;
  --secondary-color: #FFB347;
  --success-color: #09BB07;
  --warning-color: #F76260;
  --text-color: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --border-color: #F0F0F0;
  --background-color: #FAFAFA;
  --card-background: #FFFFFF;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
  font-size: 16px;
  color: var(--text-color);
  background-color: #FFFFFF;
}

/* 通用类 */
.container {
  min-height: 100vh;
  background-color: #FFFFFF;
}

/* 卡片样式 */
.card {
  background-color: var(--card-background);
  border-radius: 12rpx;
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: none;
  border: 1rpx solid var(--border-color);
}

/* 按钮样式 */
.btn-primary {
  background-color: var(--primary-color);
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary:active {
  opacity: 0.8;
}

/* 文本省略 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* flex布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* 价格样式 */
.price {
  color: var(--warning-color);
  font-weight: bold;
}

.price::before {
  content: '¥';
  font-size: 24rpx;
}
